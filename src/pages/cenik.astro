</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.expand-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const targetId = btn.dataset.target!;
      const detail = document.getElementById(targetId)!;
      const isOpen = detail.classList.contains('is-open');

      const label = btn.querySelector<HTMLElement>('.toggle-label')!;
      if (isOpen) {
        detail.classList.remove('is-open');
        detail.setAttribute('aria-hidden', 'true');
        btn.setAttribute('aria-expanded', 'false');
        label.textContent = 'Zobrazit více';
      } else {
        detail.classList.add('is-open');
        detail.setAttribute('aria-hidden', 'false');
        btn.setAttribute('aria-expanded', 'true');
        label.textContent = 'Zobrazit méně';
      }
    });
  });
</script>

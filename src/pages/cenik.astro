---

<Layout
  title="Ceník"
  description="Ceník kosmetického salonu JANESKIN — Dolní Lutyně. Ceny všech ošetření, masáží, laminací, vizážistiky a svatebních balíčků. Jana Szymiková."
>
  <PageHeader
    title="Ceník služeb"
    subtitle="Přehledný ceník všech ošetření. Ceny jsou orientační — konečná cena závisí na délce a rozsahu ošetření."
    breadcrumb={[{ label: 'Ceník', href: '/cenik' }]}
    image="/images/bg-cenik.webp"
  />

  <!-- Kategorie navigace -->
  <div class="cenik-nav">
    <div class="container">
      <ul class="cenik-nav__list" role="list">
        {pricingData.map(cat => (
          <li>
            <a href={`#${cat.id}`} class="cenik-nav__link">{cat.category}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="cenik-content section">
    <div class="container">

      <!-- Kategorie -->
      {pricingData.map(cat => (
        <section class="price-category" id={cat.id} aria-label={cat.category}>
          <h2 class="price-category__title">{cat.category}</h2>
          {cat.note && <p class="price-category__note">{cat.note}</p>}
          {cat.intro && <p class="price-category__intro">{cat.intro}</p>}

          {cat.subsections ? (
            cat.subsections.map((sub: any, subIdx: number) => (
              <>
                {sub.title && <h3 class="price-subsection__title">{sub.title}</h3>}
                {sub.intro && <p class="price-subsection__intro">{sub.intro}</p>}
                {sub.items.length > 0 && (
                <table class="price-table" role="table" aria-label={`Ceník — ${cat.category} — ${sub.title}`}>
                  <tbody>
                    {sub.items.map((item: any, i: number) => (
                      <>
                        <tr class={`price-table__row${item.description ? ' is-expandable' : ''}`}>
                          <td class="price-table__td price-table__name">
                            <div class="price-table__name-wrap">
                              <span class="price-table__name-text">
                                {item.name}
                                {item.note && <span class="price-table__note">{item.note}</span>}
                              </span>
                              {item.description && (
                                <button
                                  class="expand-toggle"
                                  aria-expanded="false"
                                  data-target={`detail-${cat.id}-s${subIdx}-${i}`}
                                >
                                  <span class="toggle-label">Zobrazit více</span>
                                  <svg class="toggle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                                </button>
                              )}
                            </div>
                          </td>
                          <td class="price-table__td price-table__duration">{item.duration}</td>
                          <td class="price-table__td price-table__price">
                            {item.price
                              ? <Badge text={item.price} variant="gold" />
                              : <span class="price-table__no-price">—</span>
                            }
                          </td>
                        </tr>
                        {item.description && (
                          <tr class="price-table__detail" id={`detail-${cat.id}-s${subIdx}-${i}`} aria-hidden="true">
                            <td colspan="3" class="price-table__detail-td">
                              <div class="price-table__detail-body">
                                <p>{item.description}</p>
                              </div>
                            </td>
                          </tr>
                        )}
                      </>
                    ))}
                  </tbody>
                </table>
                )}
              </>
            ))
          ) : (
            <table class="price-table" role="table" aria-label={`Ceník — ${cat.category}`}>
              <tbody>
                {cat.items.map((item: any, i: number) => (
                  <>
                    <tr class={`price-table__row${item.description ? ' is-expandable' : ''}`}>
                      <td class="price-table__td price-table__name">
                        <div class="price-table__name-wrap">
                          <span class="price-table__name-text">
                            {item.name}
                            {item.note && <span class="price-table__note">{item.note}</span>}
                          </span>
                          {item.description && (
                            <button
                              class="expand-toggle"
                              aria-expanded="false"
                              data-target={`detail-${cat.id}-${i}`}
                            >
                              <span class="toggle-label">Zobrazit více</span>
                              <svg class="toggle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                            </button>
                          )}
                        </div>
                      </td>
                      <td class="price-table__td price-table__duration">{item.duration}</td>
                      <td class="price-table__td price-table__price">
                        {item.price
                          ? <Badge text={item.price} variant="gold" />
                          : <span class="price-table__no-price">—</span>
                        }
                      </td>
                    </tr>
                    {item.description && (
                      <tr class="price-table__detail" id={`detail-${cat.id}-${i}`} aria-hidden="true">
                        <td colspan="3" class="price-table__detail-td">
                          <div class="price-table__detail-body">
                            <p>{item.description}</p>
                          </div>
                        </td>
                      </tr>
                    )}
                  </>
                ))}
              </tbody>
            </table>
          )}
        </section>
      ))}

      <!-- Dárkové poukazy -->
      <section class="price-category" id="darkove-poukazy" aria-label="Dárkové poukazy">
        <h2 class="price-category__title">Dárkové poukazy</h2>
        <p class="voucher-intro">Chcete mít jistotu, že při výběru dárku nešlápnete vedle? Dárkový poukaz bude ta správná volba. Obdarovaná si sama vybere, na jakou kosmetickou proceduru poukaz využije – v nabídce jsou specializovaná kosmetická ošetření, omlazující mikroneedling, masáže, laminace řas a obočí, kurz líčení nebo péče o pleť. Věnujte dárkový poukaz, kterým zároveň darujete milované osobě čas pro sebe, relaxaci a tolik potřebný odpočinek.</p>
        <div class="voucher-grid">
          {[
            { price: '1 000 Kč', duration: '60 min' },
            { price: '1 500 Kč', duration: '90 min' },
            { price: '2 000 Kč', duration: '90 min' },
          ].map(v => (
            <div class="voucher-card">
              <p class="voucher-card__label">Dárkový poukaz</p>
              <p class="voucher-card__value">{v.price}</p>
              <p class="voucher-card__duration">{v.duration}</p>
              <p class="voucher-card__validity">Platnost 6 měsíců</p>
            </div>
          ))}
        </div>
        <p class="voucher-footer">K dispozici jsou luxusní poukazy v tištěné podobě s dárkovou obálkou a mašlí, nebo v elektronické podobě zaslanou na e-mail. Hodnotu poukazu je možné zvolit i individuálně dle Vašeho přání. Poukazy je možné vyzvednout po domluvě v SALONU JANESKIN. Platnost poukazu je 6 měsíců od data zakoupení, pokud není dohodnuto jinak.</p>
      </section>

      <div class="cenik-cta">
        <Button href="https://noona.app/cs/janeskinsalonjanaszymikova" variant="primary" size="lg" target="_blank" rel="noopener noreferrer">Objednat se</Button>
        <Button href="tel:+420724239998" variant="outline" size="lg">Zavolat</Button>
      </div>
    </div>
  </div>

</Layout>

<style>
  /* Category nav */
  .cenik-nav {
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 72px;
    z-index: calc(var(--z-header) - 1);
  }

  .cenik-nav__list {
    list-style: none;
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .cenik-nav__list::-webkit-scrollbar { display: none; }

  .cenik-nav__link {
    display: block;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-soft);
    text-decoration: none;
    padding: var(--space-4) var(--space-4);
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .cenik-nav__link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* Info banner */
  .cenik-info {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    background-color: var(--color-accent-light);
    border: 1px solid var(--color-accent-light);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-12);
    color: var(--color-accent-hover);
